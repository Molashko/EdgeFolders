<Window x:Class="EdgeFolders.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:EdgeFolders.Controls"
        xmlns:models="clr-namespace:EdgeFolders.Models"
        Title="EdgeFolders"
        Width="960"
        Height="320"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        Focusable="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <Style x:Key="GlassRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassScrollThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="ThumbRoot"
                                Background="#4A202126"
                                BorderBrush="#1FFFFFFF"
                                BorderThickness="1"
                                CornerRadius="3" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbRoot" Property="Background" Value="#66202126" />
                                <Setter TargetName="ThumbRoot" Property="BorderBrush" Value="#2BFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbRoot" Property="Background" Value="#78202126" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ResizeThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Opacity" Value="0.46" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="ResizeRoot"
                                Background="#30FFFFFF"
                                CornerRadius="4" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ResizeRoot" Property="Background" Value="#55FFFFFF" />
                                <Setter Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ResizeRoot" Property="Background" Value="#70FFFFFF" />
                                <Setter Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="VerticalGlassScrollBarTemplate" TargetType="{x:Type ScrollBar}">
            <Grid Width="4" Background="Transparent">
                <Track x:Name="PART_Track"
                       IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource GlassRepeatButtonStyle}" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource GlassScrollThumbStyle}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource GlassRepeatButtonStyle}" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="HorizontalGlassScrollBarTemplate" TargetType="{x:Type ScrollBar}">
            <Grid Height="4" Background="Transparent">
                <Track x:Name="PART_Track"
                       IsDirectionReversed="False">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource GlassRepeatButtonStyle}" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource GlassScrollThumbStyle}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource GlassRepeatButtonStyle}" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="4" />
            <Setter Property="MinWidth" Value="4" />
            <Setter Property="Template" Value="{StaticResource VerticalGlassScrollBarTemplate}" />
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Height" Value="4" />
                    <Setter Property="MinHeight" Value="4" />
                    <Setter Property="Template" Value="{StaticResource HorizontalGlassScrollBarTemplate}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="LaunchTileTemplate" DataType="{x:Type models:LaunchItem}">
            <Button Tag="{Binding}"
                    Click="LaunchItem_Click"
                    MouseEnter="Tile_MouseEnter"
                    MouseLeave="Tile_MouseLeave"
                    PreviewMouseLeftButtonDown="Tile_PreviewMouseLeftButtonDown"
                    ToolTip="{Binding Title}"
                    Width="68"
                    Height="68"
                    Margin="0,3,0,0"
                    Padding="0"
                    Cursor="Hand"
                    Background="Transparent"
                    BorderThickness="0"
                    ClipToBounds="False"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    RenderTransformOrigin="0.5,0.5">
                <Button.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                        <TranslateTransform Y="0" />
                    </TransformGroup>
                </Button.RenderTransform>
                <Button.Template>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Tile"
                                Background="#0DFFFFFF"
                                BorderBrush="#12FFFFFF"
                                BorderThickness="1"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <Grid Margin="7">
                                <Border Width="50"
                                        Height="50"
                                        CornerRadius="9"
                                        Background="#0AFFFFFF"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <Image Source="{Binding Path, Converter={StaticResource FileIconConverter}}"
                                           Width="38"
                                           Height="38"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Tile" Property="Background" Value="#18FFFFFF" />
                                <Setter TargetName="Tile" Property="BorderBrush" Value="#28FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Tile" Property="Background" Value="#22FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="FolderCardTemplate" DataType="{x:Type models:FolderGroup}">
            <Border x:Name="FolderCard"
                    Width="{Binding Width}"
                    Height="{Binding Height}"
                    Margin="0"
                    Padding="14,9,12,10"
                    Background="#4A202126"
                    BorderBrush="#1FFFFFFF"
                    BorderThickness="1"
                    CornerRadius="16"
                    SnapsToDevicePixels="True"
                    AllowDrop="True"
                    Loaded="FolderCard_Loaded"
                    MouseEnter="FolderCard_MouseEnter"
                    MouseLeave="FolderCard_MouseLeave"
                    Drop="FolderCard_Drop"
                    DragEnter="FolderCard_DragEnter"
                    DragOver="FolderCard_DragEnter"
                    RenderTransformOrigin="0.5,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24"
                                      ShadowDepth="9"
                                      Direction="270"
                                      Opacity="0.16"
                                      Color="#000000" />
                </Border.Effect>
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                        <TranslateTransform Y="0" />
                    </TransformGroup>
                </Border.RenderTransform>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="0" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Background="{Binding Accent}"
                                        CornerRadius="3"
                                        Height="20"
                                        VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Name}"
                                           Foreground="{StaticResource InkBrush}"
                                           FontSize="14"
                                           FontWeight="ExtraBold"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                            </Grid>
                            <Rectangle Height="1"
                                       Fill="#12FFFFFF"
                                       Margin="0,8,0,0" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                MinWidth="26"
                                Height="22"
                                Padding="7,0"
                                Background="#0AFFFFFF"
                                BorderBrush="#10FFFFFF"
                                BorderThickness="1"
                                CornerRadius="8"
                                VerticalAlignment="Top">
                            <TextBlock Text="{Binding Items.Count}"
                                       Foreground="{StaticResource MutedInkBrush}"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2"
                          Margin="0,0,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      PanningMode="VerticalOnly">
                            <ItemsControl ItemsSource="{Binding Items}"
                                          ItemTemplate="{StaticResource LaunchTileTemplate}"
                                          Width="{Binding Width, Converter={StaticResource NumericOffsetConverter}, ConverterParameter=-36}"
                                          Margin="0,0,0,0"
                                          HorizontalAlignment="Center">
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="{x:Type ContentPresenter}">
                                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                                        <Setter Property="VerticalAlignment" Value="Stretch" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <controls:CenteredWrapPanel ItemWidth="82"
                                                                    ItemHeight="80"
                                                                    MinColumnGap="2"
                                                                    MaxColumnGap="20" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>

                        <TextBlock Text="Перетащи сюда"
                                   Foreground="{StaticResource MutedInkBrush}"
                                   FontSize="12"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Items.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Thumb Grid.RowSpan="3"
                           Style="{StaticResource ResizeThumbStyle}"
                           Width="7"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Stretch"
                           Margin="0,34,-8,22"
                           Cursor="SizeWE"
                           DragDelta="ResizeRightThumb_DragDelta"
                           DragCompleted="ResizeThumb_DragCompleted" />
                    <Thumb Grid.Row="2"
                           Style="{StaticResource ResizeThumbStyle}"
                           Height="7"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Bottom"
                           Margin="36,0,22,-8"
                           Cursor="SizeNS"
                           DragDelta="ResizeBottomThumb_DragDelta"
                           DragCompleted="ResizeThumb_DragCompleted" />
                    <Thumb Grid.Row="2"
                           Style="{StaticResource ResizeThumbStyle}"
                           Width="18"
                           Height="18"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           Margin="0,0,-9,-9"
                           Cursor="SizeNWSE"
                           DragDelta="ResizeCornerThumb_DragDelta"
                           DragCompleted="ResizeThumb_DragCompleted" />
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid x:Name="WindowRoot"
          MouseLeave="WindowRoot_MouseLeave">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="TopHandle"
                Width="116"
                Height="4"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Background="#A0FFCA5F"
                CornerRadius="0,0,5,5"
                Opacity="0.92" />

        <Grid Grid.Row="1"
              Margin="0"
              ClipToBounds="False">
            <ScrollViewer x:Name="FoldersScroll"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Top"
                          VerticalContentAlignment="Top"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          PanningMode="HorizontalOnly"
                          CanContentScroll="False"
                          AllowDrop="True"
                          ClipToBounds="False"
                          Drop="DropFiles">
                <ItemsControl x:Name="FoldersCards"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Top"
                              MinWidth="{Binding ActualWidth, ElementName=FoldersScroll}"
                              ItemsSource="{Binding Folders}"
                              ItemTemplate="{StaticResource FolderCardTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <controls:CenteredRowPanel Gap="14" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <Border HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,0,2,0"
                    Padding="6"
                    Background="#4A1A1B1F"
                    BorderBrush="#1AFFFFFF"
                    BorderThickness="1"
                    CornerRadius="0,0,14,14"
                    Effect="{StaticResource PanelShadow}">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource IconButtonStyle}"
                            Content="&#x2699;"
                            ToolTip="Settings"
                            PreviewMouseLeftButtonUp="OpenSettings_Click"
                            Click="OpenSettings_Click" />
                    <Button Style="{StaticResource IconButtonStyle}"
                            Content="&#x00D7;"
                            FontSize="18"
                            Margin="6,0,0,0"
                            ToolTip="Hide"
                            Click="Hide_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
