<Window x:Class="EdgeFolders.Windows.ItemEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Элемент"
        Width="620"
        Height="430"
        MinWidth="560"
        MinHeight="390"
        WindowStartupLocation="CenterOwner"
        Background="#FF18191C">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Элемент панели"
                       Foreground="{StaticResource InkBrush}"
                       FontSize="20"
                       FontWeight="ExtraBold" />
            <TextBlock Text="Можно запускать приложения, ярлыки, папки, файлы и URL."
                       Foreground="{StaticResource MutedInkBrush}"
                       FontSize="12"
                       Margin="0,4,0,0" />
        </StackPanel>

        <Grid Grid.Row="1"
              Margin="0,22,0,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="Название"
                       Foreground="{StaticResource MutedInkBrush}"
                       VerticalAlignment="Center" />
            <TextBox x:Name="TitleBox"
                     Grid.Column="1"
                     Grid.ColumnSpan="3" />

            <TextBlock Grid.Row="2"
                       Text="Путь / URL"
                       Foreground="{StaticResource MutedInkBrush}"
                       VerticalAlignment="Center" />
            <TextBox x:Name="PathBox"
                     Grid.Row="2"
                     Grid.Column="1" />
            <Button Grid.Row="2"
                    Grid.Column="3"
                    Content="Файл"
                    Style="{StaticResource SecondaryButtonStyle}"
                    MinWidth="72"
                    Click="BrowseFile_Click" />

            <TextBlock Grid.Row="4"
                       Text="Аргументы"
                       Foreground="{StaticResource MutedInkBrush}"
                       VerticalAlignment="Center" />
            <TextBox x:Name="ArgumentsBox"
                     Grid.Row="4"
                     Grid.Column="1"
                     Grid.ColumnSpan="3" />

            <TextBlock Grid.Row="6"
                       Text="Рабочая папка"
                       Foreground="{StaticResource MutedInkBrush}"
                       VerticalAlignment="Center" />
            <TextBox x:Name="WorkingDirectoryBox"
                     Grid.Row="6"
                     Grid.Column="1" />
            <Button Grid.Row="6"
                    Grid.Column="3"
                    Content="Папка"
                    Style="{StaticResource SecondaryButtonStyle}"
                    MinWidth="72"
                    Click="BrowseFolder_Click" />

            <CheckBox x:Name="RunAsAdminCheck"
                      Grid.Row="8"
                      Grid.Column="1"
                      Grid.ColumnSpan="3"
                      Content="Запускать от имени администратора" />
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Отмена"
                    Style="{StaticResource SecondaryButtonStyle}"
                    MinWidth="96"
                    Margin="0,0,8,0"
                    Click="Cancel_Click" />
            <Button Content="Сохранить"
                    Style="{StaticResource PrimaryButtonStyle}"
                    MinWidth="112"
                    Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
