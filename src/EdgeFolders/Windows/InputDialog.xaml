<Window x:Class="EdgeFolders.Windows.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EdgeFolders"
        Width="420"
        Height="190"
        MinWidth="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF18191C">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptText"
                   Foreground="{StaticResource InkBrush}"
                   FontSize="15"
                   FontWeight="Bold"
                   TextWrapping="Wrap" />

        <TextBox x:Name="ValueBox"
                 Grid.Row="1"
                 Margin="0,18,0,0"
                 Height="38"
                 VerticalAlignment="Top" />

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Отмена"
                    Style="{StaticResource SecondaryButtonStyle}"
                    MinWidth="90"
                    Margin="0,0,8,0"
                    Click="Cancel_Click" />
            <Button Content="OK"
                    Style="{StaticResource PrimaryButtonStyle}"
                    MinWidth="90"
                    Click="Ok_Click" />
        </StackPanel>
    </Grid>
</Window>
