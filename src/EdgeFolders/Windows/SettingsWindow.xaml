<Window x:Class="EdgeFolders.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:EdgeFolders.Models"
        Title="EdgeFolders Settings"
        Icon="/Assets/AppIcon.ico"
        Width="1020"
        Height="680"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#FF18191C">
    <Window.Resources>
        <DataTemplate x:Key="SettingsItemTemplate" DataType="{x:Type models:LaunchItem}">
            <Grid Margin="0,0,0,8"
                  MinHeight="58">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Width="42"
                        Height="42"
                        Background="#24FFFFFF"
                        BorderBrush="#20FFFFFF"
                        BorderThickness="1"
                        CornerRadius="8"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                    <Image Source="{Binding Path, Converter={StaticResource FileIconConverter}}"
                           Width="28"
                           Height="28"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Border>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}"
                               Foreground="{StaticResource InkBrush}"
                               FontWeight="Bold"
                               FontSize="14"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Path}"
                               Foreground="{StaticResource MutedInkBrush}"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <Style x:Key="SettingsListBoxStyle" TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="#121314" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="#24FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type ListBoxItem}">
                        <Setter Property="Padding" Value="10,8" />
                        <Setter Property="Margin" Value="0,0,0,6" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                    <Border x:Name="Row"
                                            Background="#10FFFFFF"
                                            BorderBrush="#12FFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Row" Property="Background" Value="#20FFFFFF" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Row" Property="Background" Value="#34FFCA5F" />
                                            <Setter TargetName="Row" Property="BorderBrush" Value="#70FFCA5F" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="EdgeFolders"
                           Foreground="{StaticResource InkBrush}"
                           FontSize="26"
                           FontWeight="ExtraBold" />
                <TextBlock Text="Папки, приложения и поведение верхней панели."
                           Foreground="{StaticResource MutedInkBrush}"
                           FontSize="13"
                           Margin="0,4,0,0" />
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Открыть конфиг"
                    Style="{StaticResource SecondaryButtonStyle}"
                    MinWidth="132"
                    VerticalAlignment="Center"
                    Click="OpenConfig_Click" />
        </Grid>

        <Grid Grid.Row="1"
              Margin="0,22,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Папки"
                           Foreground="{StaticResource InkBrush}"
                           FontSize="16"
                           FontWeight="ExtraBold"
                           Margin="0,0,0,10" />

                <ListBox x:Name="FoldersList"
                         Grid.Row="1"
                         Style="{StaticResource SettingsListBoxStyle}"
                         SelectionChanged="FoldersList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:FolderGroup}">
                            <Grid MinHeight="42">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Background="{Binding Accent}"
                                        CornerRadius="2"
                                        Margin="0,6" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Name}"
                                           Foreground="{StaticResource InkBrush}"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="3"
                                           Text="{Binding Items.Count}"
                                           Foreground="{StaticResource MutedInkBrush}"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <WrapPanel Grid.Row="2"
                           Margin="0,12,0,0">
                    <Button Content="Добавить"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,8"
                            Click="AddFolder_Click" />
                    <Button Content="Переименовать"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,8"
                            Click="RenameFolder_Click" />
                    <Button Content="Удалить"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,8"
                            Click="DeleteFolder_Click" />
                    <Button Content="↑"
                            Style="{StaticResource IconButtonStyle}"
                            Margin="0,0,8,8"
                            Click="MoveFolderUp_Click" />
                    <Button Content="↓"
                            Style="{StaticResource IconButtonStyle}"
                            Margin="0,0,8,8"
                            Click="MoveFolderDown_Click" />
                </WrapPanel>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ItemsTitle"
                               Text="Элементы"
                               Foreground="{StaticResource InkBrush}"
                               FontSize="16"
                               FontWeight="ExtraBold" />
                    <TextBlock Grid.Column="1"
                               Text="Можно перетаскивать .exe, .lnk, файлы и папки"
                               Foreground="{StaticResource MutedInkBrush}"
                               FontSize="12"
                               VerticalAlignment="Center" />
                </Grid>

                <ListBox x:Name="ItemsList"
                         Grid.Row="1"
                         Style="{StaticResource SettingsListBoxStyle}"
                         ItemTemplate="{StaticResource SettingsItemTemplate}"
                         AllowDrop="True"
                         Drop="ItemsList_Drop" />

                <WrapPanel Grid.Row="2"
                           Margin="0,12,0,0">
                    <Button Content="Приложение"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,8"
                            Click="AddApp_Click" />
                    <Button Content="Папка"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,8"
                            Click="AddFolderItem_Click" />
                    <Button Content="URL"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,8"
                            Click="AddUrl_Click" />
                    <Button Content="Изменить"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,8"
                            Click="EditItem_Click" />
                    <Button Content="Удалить"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,8"
                            Click="DeleteItem_Click" />
                    <Button Content="↑"
                            Style="{StaticResource IconButtonStyle}"
                            Margin="0,0,8,8"
                            Click="MoveItemUp_Click" />
                    <Button Content="↓"
                            Style="{StaticResource IconButtonStyle}"
                            Margin="0,0,8,8"
                            Click="MoveItemDown_Click" />
                </WrapPanel>
            </Grid>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <WrapPanel VerticalAlignment="Center">
                <CheckBox x:Name="EnableEdgeCheck"
                          Content="Показывать при наведении на верхний край"
                          Margin="0,0,20,8" />
                <CheckBox x:Name="StartWithWindowsCheck"
                          Content="Запускать вместе с Windows"
                          Margin="0,0,20,8" />

                <TextBlock Text="Высота"
                           Foreground="{StaticResource MutedInkBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,8" />
                <TextBox x:Name="PanelHeightBox"
                         Width="58"
                         Margin="0,0,14,8" />

                <TextBlock Text="Зона"
                           Foreground="{StaticResource MutedInkBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,8" />
                <TextBox x:Name="HotZoneBox"
                         Width="48"
                         Margin="0,0,14,8" />

                <TextBlock Text="Задержка"
                           Foreground="{StaticResource MutedInkBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,8" />
                <TextBox x:Name="HideDelayBox"
                         Width="66"
                         Margin="0,0,14,8" />
            </WrapPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Сохранить"
                        Style="{StaticResource PrimaryButtonStyle}"
                        MinWidth="112"
                        Margin="0,0,8,0"
                        Click="SaveSettings_Click" />
                <Button Content="Закрыть"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinWidth="96"
                        Click="Close_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
